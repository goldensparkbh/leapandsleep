[debug] [2026-03-24T17:42:50.887Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/leapandsleep0/rulesets {"name":"projects/leapandsleep0/rulesets/fa78eacd-f3b4-463b-b7b6-bc8ea78cc80d","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    match /users/{userId} {\n      allow read, create, update: if isAuthenticated() && request.auth.uid == userId;\n      allow delete: if false;\n    }\n\n    match /posts/{postId} {\n      allow read: if true;\n      allow create, update, delete: if isAuthenticated();\n    }\n\n    match /comments/{commentId} {\n      allow read: if isAuthenticated() || resource.data.status == 'visible';\n      allow create, update, delete: if isAuthenticated();\n    }\n\n    match /commentModeration/{commentId} {\n      allow read, write: if isAuthenticated();\n    }\n\n    match /blockedCommentIps/{ipHash} {\n      allow read, write: if isAuthenticated();\n    }\n\n    match /categories/{categoryId} {\n      allow read: if true;\n      allow write: if isAuthenticated();\n    }\n\n    match /tools/{toolId} {\n      allow read: if true;\n      allow write: if isAuthenticated();\n    }\n\n    match /toolCategories/{categoryId} {\n      allow read: if true;\n      allow write: if isAuthenticated();\n    }\n\n    match /comparisons/{comparisonId} {\n      allow read: if true;\n      allow write: if isAuthenticated();\n    }\n\n    match /affiliateLinks/{linkId} {\n      allow read: if true;\n      allow write: if isAuthenticated();\n    }\n\n    match /resources/{resourceId} {\n      allow read: if true;\n      allow write: if isAuthenticated();\n    }\n\n    match /subscribers/{subscriberId} {\n      allow create: if true;\n      allow read, update, delete: if isAuthenticated();\n    }\n\n    match /leads/{leadId} {\n      allow create: if true;\n      allow read, update, delete: if isAuthenticated();\n    }\n\n    match /settings/{settingId} {\n      allow read: if true;\n      allow write: if isAuthenticated();\n    }\n\n    match /media/{mediaId} {\n      allow read: if true;\n      allow write: if isAuthenticated();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-24T17:42:47.859519Z","metadata":{"services":["cloud.firestore"]}}
